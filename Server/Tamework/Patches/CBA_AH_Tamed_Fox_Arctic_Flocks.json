{
  "Id": "CBA_AH_Tamed_Fox_Arctic_Flocks",
  "$Comment": "Patch any loaded adult Fox_Arctic role so wild flocks can include CBA cubs. TargetExists is evaluated per target.",
  "Target": "Server/NPC/Roles/Creature/Mammal/Tamed/Tamed_Fox_Arctic.json",
  "When": {
    "TargetExists": true
  },
  "Priority": 20,
  "Enabled": true,
  "Operations": [
    {
      "Id": "set-adult-tamed-fox-arctic-flock-array",
      "Op": "Merge",
      "Path": "/",
      "Value": {
        "Modify": {
          "FlockArray": [
            "Tamed_Fox_Arctic",
            "Tamed_Fox_Arctic_Cub"
          ]
        }
      }
    }
  ]
}
