{
  "Id": "CBA_AH_Beast_Interactions",
  "$Comment": "Only runs when AH is installed. Adds CBA Beast babies to AHIntBeast instead of maintaining a parallel CBA interaction config.",
  "When": {
    "ModInstalled": "Alechilles:Alec's Animal Husbandry!"
  },
  "Target": "Server/Tamework/Interactions/AHIntBeast.json",
  "Priority": 40,
  "Enabled": true,
  "Operations": [
    {
      "Id": "add-fox-cub-role-id",
      "Op": "Insert",
      "Path": "/RoleIds",
      "Position": "End",
      "Value": "Fox_Cub"
    },
    {
      "Id": "add-tamed-fox-cub-role-id",
      "Op": "Insert",
      "Path": "/RoleIds",
      "Position": "End",
      "Value": "Tamed_Fox_Cub"
    },
    {
      "Id": "add-fox-arctic-cub-role-id",
      "Op": "Insert",
      "Path": "/RoleIds",
      "Position": "End",
      "Value": "Fox_Arctic_Cub"
    },
    {
      "Id": "add-tamed-fox-arctic-cub-role-id",
      "Op": "Insert",
      "Path": "/RoleIds",
      "Position": "End",
      "Value": "Tamed_Fox_Arctic_Cub"
    }
  ]
}
