{
  "Id": "CBA_AH_Neutral_Needs",
  "$Comment": "Only runs when AH is installed. Adds CBA neutral tamed babies to AHNeedsMain instead of maintaining a parallel CBA needs config.",
  "When": {
    "ModInstalled": "Alechilles:Alec's Animal Husbandry!"
  },
  "Target": "Server/Tamework/Needs/AHNeedsMain.json",
  "Priority": 40,
  "Enabled": true,
  "Operations": [
    {
      "Id": "add-tamed-tetrabird-chick-role-id",
      "Op": "Insert",
      "Path": "/RoleIds",
      "Position": "End",
      "Value": "Tamed_Tetrabird_Chick"
    },
    {
      "Id": "add-tamed-flamingo-chick-role-id",
      "Op": "Insert",
      "Path": "/RoleIds",
      "Position": "End",
      "Value": "Tamed_Flamingo_Chick"
    }
  ]
}
