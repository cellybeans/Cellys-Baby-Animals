{
  "Id": "CBA_Tetrabird_AH_Tamed_Roles",
  "$Comment": "Only runs when AH is installed. Tamed chicks switch from the vanilla livestock template to AH's tamed livestock template.",
  "When": {
    "ModInstalled": "Alechilles:Alec's Animal Husbandry!"
  },
  "Target": "Server/NPC/Roles/Avian/Raptor/Tamed/Tamed_Tetrabird_Chick.json",
  "Priority": 30,
  "Enabled": true,
  "Operations": [
    {
      "Id": "use-ah-tamed-template-for-tetrabird-chick",
      "Op": "Replace",
      "Path": "/Reference",
      "Value": "AH_Template_Livestock_Tamed"
    },
    {
      "Id": "add-ah-command-capabilities-for-tetrabird-chick",
      "Op": "Merge",
      "Path": "/Modify",
      "Value": {
        "IsMemory": false,
        "AttitudeGroup": "AH_Livestock_Tamed",
        "AttractiveItemSetParticles": "Want_Food_Wild_Berry_Red",
        "FoodItemIDs": [
          "Plant_Fruit_Berries_Red"
        ],
        "CanFollow": true,
        "CanHold": true,
        "CanDefend": false,
        "CanAttackTarget": false,
        "CanMoveToLocation": true,
        "CanReturnHome": true,
        "CanRecall": true,
        "CanSetHome": true,
        "CanBreedPair": true
      }
    }
  ]
}
